#!/bin/sh

echo "========================================="
echo " pre-push: テスト・カバレッジ・ミューテーション確認"
echo "========================================="
echo ""

FAILED=0
THRESHOLD=80

check_mutation_score() {
  local dir=$1
  local output_file=$2

  local score_line=$(grep "^All files" "$output_file")
  if [ -z "$score_line" ]; then
    echo "✗ ミューテーションスコアをパースできませんでした。"
    return 1
  fi

  local score=$(echo "$score_line" | awk -F'|' '{gsub(/ /, "", $2); print $2}')
  echo "ミューテーションスコア: ${score}% (閾値: ${THRESHOLD}%)"

  if [ "$(echo "$score < $THRESHOLD" | bc)" -eq 1 ]; then
    echo "✗ スコア ${score}% が閾値 ${THRESHOLD}% を下回っています。"
    return 1
  fi

  echo "✓ スコア ${score}% は閾値 ${THRESHOLD}%以上です。"
  return 0
}

# ---- Server ----
echo "[Server] ユニットテスト実行中..."
cd server && npm run test || FAILED=1
cd ..

if [ $FAILED -eq 1 ]; then
  echo ""
  echo "✗ Server ユニットテスト失敗。pushを中止します。"
  exit 1
fi

echo ""
echo "[Server] カバレッジ確認中..."
cd server && npm run test:coverage || FAILED=1
cd ..

if [ $FAILED -eq 1 ]; then
  echo ""
  echo "✗ Server カバレッジ80%未達。pushを中止します。"
  exit 1
fi

echo ""
echo "[Server] ミューテーションテスト実行中..."
cd server && npm run test:mutation > /tmp/server-mutation-output.txt 2>&1
MUTATION_EXIT=$?
cd ..

if [ $MUTATION_EXIT -ne 0 ]; then
  cat /tmp/server-mutation-output.txt
  echo ""
  echo "✗ Server ミューテーションテスト実行失敗。pushを中止します。"
  exit 1
fi

tail -30 /tmp/server-mutation-output.txt

echo ""
echo "[Server] ミューテーションスコア確認中..."
check_mutation_score server /tmp/server-mutation-output.txt
if [ $? -ne 0 ]; then
  echo ""
  echo "✗ Server ミューテーションスコア${THRESHOLD}%未達。pushを中止します。"
  exit 1
fi

# ---- Client ----
echo ""
echo "[Client] ユニットテスト実行中..."
cd client && npm run test || FAILED=1
cd ..

if [ $FAILED -eq 1 ]; then
  echo ""
  echo "✗ Client ユニットテスト失敗。pushを中止します。"
  exit 1
fi

echo ""
echo "[Client] カバレッジ確認中..."
cd client && npm run test:coverage || FAILED=1
cd ..

if [ $FAILED -eq 1 ]; then
  echo ""
  echo "✗ Client カバレッジ80%未達。pushを中止します。"
  exit 1
fi

echo ""
echo "[Client] ミューテーションテスト実行中..."
cd client && npm run test:mutation > /tmp/client-mutation-output.txt 2>&1
MUTATION_EXIT=$?
cd ..

if [ $MUTATION_EXIT -ne 0 ]; then
  cat /tmp/client-mutation-output.txt
  echo ""
  echo "✗ Client ミューテーションテスト実行失敗。pushを中止します。"
  exit 1
fi

tail -30 /tmp/client-mutation-output.txt

echo ""
echo "[Client] ミューテーションスコア確認中..."
check_mutation_score client /tmp/client-mutation-output.txt
if [ $? -ne 0 ]; then
  echo ""
  echo "✗ Client ミューテーションスコア${THRESHOLD}%未達。pushを中止します。"
  exit 1
fi

echo ""
echo "========================================="
echo " 全テスト合格 ✓ pushを続行します"
echo "========================================="
